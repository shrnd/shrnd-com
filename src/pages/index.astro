---
import ArrowIcon from '../components/ArrowIcon.astro';
import MotionStudy from '../components/MotionStudy.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const capabilities = [
  {
    title: 'Moving image',
    description: 'Camera and video, composed in real time inside focused consumer apps.',
  },
  {
    title: 'Expressive interaction',
    description:
      'Native interfaces that move with purpose — quick, tactile, polished to the pixel.',
  },
  {
    title: 'Intelligent tools',
    description:
      'AI that removes friction and expands what people can create — never a substitute for taste.',
  },
];

const engineCapabilities = [
  'Real-time rendering',
  'Capture systems',
  'Timeline & playback',
  'Motion system',
  'Creative tooling',
  'AI-assisted creation',
];

const organisation = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SHRND LTD',
  legalName: 'SHRND LTD',
  url: 'https://shrnd.com',
  email: 'contact@shrnd.com',
  identifier: '17350332',
  logo: 'https://shrnd.com/apple-touch-icon.png',
  description: 'Independent app studio in London building original apps for Apple platforms.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '71-75 Shelton Street, Covent Garden',
    addressLocality: 'London',
    postalCode: 'WC2H 9JQ',
    addressCountry: 'GB',
  },
};
---

<BaseLayout
  title="SHRND — Independent App Studio"
  description="SHRND is an independent app studio in London, building original apps for iPhone, iPad and Mac — camera, video and creative tools with meticulously crafted interfaces."
>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <SiteHeader isHome />

  <main id="main-content">
    <div class="hero" data-hero>
      <div class="hero__art">
        <MotionStudy />
      </div>

      <section class="hero__content" aria-labelledby="hero-title">
        <h1 id="hero-title" class="hero__title hero-reveal hero-reveal--one">
          <span>Every frame,</span>
          <span>considered.</span>
        </h1>

        <div class="hero__footer hero-reveal hero-reveal--two">
          <p class="hero__description">
            Original apps for iPhone, iPad and Mac — camera, video and <span class="no-break"
              >AI-assisted</span
            > creative tools, finished down to the smallest interaction.
          </p>
          <a class="text-link text-link--light" href="#what-we-build">
            <span>What we build</span>
            <ArrowIcon />
          </a>
        </div>
      </section>

      <a class="hero__scroll" href="#what-we-build" aria-label="Continue to what we build">
        <span>Explore</span>
        <span class="hero__scroll-line"></span>
      </a>
    </div>

    <section id="what-we-build" class="section capabilities" aria-labelledby="capabilities-title">
      <div class="section__intro">
        <p class="section-label">01 · What we build</p>
        <h2 id="capabilities-title">Products.<br />Built with depth.</h2>
        <p>
          The studio exists to ship its own work. The first SHRND apps are in development now — each
          shaped around a single idea.
        </p>
      </div>

      <ul class="capability-list">
        {
          capabilities.map((capability) => (
            <li class="capability-item">
              <h3>{capability.title}</h3>
              <p>{capability.description}</p>
              <span class="capability-item__mark" aria-hidden="true">
                <ArrowIcon />
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="engine" aria-labelledby="engine-title">
      <div class="engine__inner">
        <p class="section-label section-label--light">02 · Under the surface</p>
        <h2 id="engine-title">An engine beneath<br />every detail.</h2>
        <div class="engine__copy">
          <p>
            The studio runs on technology built in-house: our own rendering, our own timelines, our
            own camera pipelines.
          </p>
          <p>You only feel it — when a phone does something it shouldn’t be able to.</p>
        </div>
        <ul class="engine__capabilities" aria-label="Foundation">
          {engineCapabilities.map((capability) => <li>{capability}</li>)}
        </ul>
      </div>
    </section>

    <section id="studio" class="section studio" aria-labelledby="studio-title">
      <p class="section-label">03 · Studio</p>
      <div class="studio__statement">
        <h2 id="studio-title">Independent.<br />By design.</h2>
        <div class="studio__copy">
          <p>
            SHRND is a small studio in London. Product, design and engineering sit at one table, so
            decisions take minutes, not meetings.
          </p>
        </div>
      </div>

      <div class="studio__principles">
        <p>Native at the core</p>
        <p>Motion with a reason</p>
        <p>Finished, not just shipped</p>
      </div>
    </section>

    <section id="contact" class="contact" aria-labelledby="contact-title">
      <p class="section-label">04 · Contact</p>
      <h2 id="contact-title">Bring us a<br />difficult problem.</h2>
      <div class="contact__copy">
        <p>
          We occasionally take on outside work: mobile engineering, media systems, performance. If
          it’s unusual, demanding and worth doing properly, we’d like to hear about it.
        </p>
      </div>
      <a class="contact__email" href="mailto:contact@shrnd.com">
        <span>contact@shrnd.com</span>
        <ArrowIcon />
      </a>
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(organisation)} />
  <script src="../scripts/hero.ts"></script>
</BaseLayout>
