---
import ArrowIcon from '../components/ArrowIcon.astro';
import LivingFrame from '../components/LivingFrame.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const capabilities = [
  {
    number: '01',
    title: 'Moving image',
    description: 'Video, camera, audio and real-time composition built into focused consumer apps.',
  },
  {
    number: '02',
    title: 'Expressive interaction',
    description:
      'Rich native interfaces, purposeful animation and tactile experiences that reward attention.',
  },
  {
    number: '03',
    title: 'Intelligent tools',
    description:
      'AI used to remove friction and expand what people can create — never as a substitute for taste.',
  },
];

const engineCapabilities = [
  'Native iOS',
  'Real-time rendering',
  'Video & audio',
  'Camera systems',
  'Motion design',
  'AI-assisted creation',
];

const organisation = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SHRND LTD',
  legalName: 'SHRND LTD',
  url: 'https://shrnd.com',
  email: 'contact@shrnd.com',
  identifier: '17350332',
  description:
    'Independent app studio building original products for Apple platforms, focused on media, motion and native performance.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '71-75 Shelton Street, Covent Garden',
    addressLocality: 'London',
    postalCode: 'WC2H 9JQ',
    addressCountry: 'GB',
  },
};
---

<BaseLayout
  title="SHRND — Independent App Studio"
  description="SHRND builds original applications for Apple platforms, focused on expressive interfaces, camera, video, real-time media and thoughtfully applied AI."
>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <SiteHeader isHome />

  <main id="main-content">
    <div class="hero" data-hero>
      <div class="hero__art">
        <LivingFrame />
      </div>

      <section class="hero__content" aria-labelledby="hero-title">
        <p class="hero__eyebrow hero-reveal hero-reveal--one">
          <span>Independent app studio</span>
          <span>London · United Kingdom</span>
        </p>

        <h1 id="hero-title" class="hero__title hero-reveal hero-reveal--two">
          <span>We make</span>
          <span>software move.</span>
        </h1>

        <div class="hero__footer hero-reveal hero-reveal--three">
          <p class="hero__description">
            SHRND builds original products for Apple platforms. We focus on expressive interfaces,
            camera and video, real-time media, and thoughtfully applied AI.
          </p>
          <a class="text-link text-link--light" href="#what-we-build">
            <span>What we build</span>
            <ArrowIcon />
          </a>
        </div>
      </section>

      <a class="hero__scroll" href="#what-we-build" aria-label="Continue to what we build">
        <span>Explore</span>
        <span class="hero__scroll-line"></span>
      </a>
    </div>

    <section id="what-we-build" class="section capabilities" aria-labelledby="capabilities-title">
      <div class="section__intro">
        <p class="section-label">01 · What we build</p>
        <h2 id="capabilities-title">Original products.<br />Built with depth.</h2>
        <p>
          Most of our work is our own. We design, develop and operate a growing family of consumer
          applications, with shared native technology underneath.
        </p>
      </div>

      <ol class="capability-list">
        {
          capabilities.map((capability) => (
            <li class="capability-item">
              <span class="capability-item__number">{capability.number}</span>
              <h3>{capability.title}</h3>
              <p>{capability.description}</p>
              <span class="capability-item__mark" aria-hidden="true">
                <ArrowIcon />
              </span>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="engine" aria-labelledby="engine-title">
      <div class="engine__inner">
        <p class="section-label section-label--light">02 · Under the surface</p>
        <h2 id="engine-title">An engine beneath<br />every detail.</h2>
        <div class="engine__copy">
          <p>
            We build below the interface when quality requires it — from rendering and timelines to
            camera pipelines and performance-critical native systems.
          </p>
          <p>
            Our apps share a foundation for media, motion and interaction, developed in-house and
            shaped by real products rather than abstract platform work.
          </p>
        </div>
        <ul class="engine__capabilities" aria-label="Core capabilities">
          {
            engineCapabilities.map((capability, index) => (
              <li>
                <span>0{index + 1}</span>
                {capability}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section id="studio" class="section studio" aria-labelledby="studio-title">
      <p class="section-label">03 · Studio</p>
      <div class="studio__statement">
        <h2 id="studio-title">Independent.<br />By design.</h2>
        <div class="studio__copy">
          <p>
            SHRND is a small, independent product company in London. Product, design and engineering
            stay close together, keeping decisions fast and the standard high.
          </p>
          <p>
            We use AI where it creates leverage. Product judgement, craft and accountability remain
            human.
          </p>
        </div>
      </div>

      <div class="studio__principles">
        <p><span>01</span>Native at the core</p>
        <p><span>02</span>Motion with a reason</p>
        <p><span>03</span>Fast process, exacting finish</p>
      </div>
    </section>

    <section id="contact" class="contact" aria-labelledby="contact-title">
      <div class="contact__topline">
        <p class="section-label section-label--light">04 · Selected collaborations</p>
        <p>Native mobile · Media · Performance</p>
      </div>
      <h2 id="contact-title">Bring us a<br />difficult problem.</h2>
      <div class="contact__copy">
        <p>
          We occasionally work with teams on ambitious product and engineering challenges —
          particularly native mobile, media systems, performance and interaction. We take on very
          few.
        </p>
        <p>
          If the problem is unusual, technically demanding and worth doing properly, we’d like to
          hear it.
        </p>
      </div>
      <p class="contact__intro">Selected collaborations and thoughtful introductions:</p>
      <a class="contact__email" href="mailto:contact@shrnd.com">
        <span>contact@shrnd.com</span>
        <ArrowIcon />
      </a>
    </section>
  </main>

  <SiteFooter />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(organisation)} />
  <script src="../scripts/hero.ts"></script>
</BaseLayout>
