---
interface Props {
  isHome?: boolean;
  paper?: boolean;
}

const { isHome = false, paper = false } = Astro.props;
const sectionPrefix = isHome ? '' : '/';
---

<header class:list={['site-header', { 'site-header--paper': paper }]}>
  <a class="wordmark" href="/" aria-label="SHRND home">SHRND</a>
  <nav class="primary-nav" aria-label="Primary navigation">
    <a href={`${sectionPrefix}#what-we-build`}>What we build</a>
    <a href={`${sectionPrefix}#studio`}>Studio</a>
    <a href={`${sectionPrefix}#contact`}>Contact</a>
  </nav>
</header>
