---
interface Props {
  hidePrivacyLink?: boolean;
}

const { hidePrivacyLink = false } = Astro.props;
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <a class="wordmark" href="/" aria-label="SHRND home">SHRND</a>
    <p class="site-footer__legal">
      SHRND LTD — registered in England and Wales, company 17350332<br />
      71–75 Shelton Street, Covent Garden, London WC2H 9JQ
    </p>
    <div class="site-footer__meta">
      {
        !hidePrivacyLink && (
          <a class="site-footer__privacy" href="/privacy">
            Privacy
          </a>
        )
      }
      <p class="site-footer__copyright">© 2026 SHRND LTD</p>
    </div>
  </div>
</footer>
